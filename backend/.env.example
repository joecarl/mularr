PORT=8940

# Telegram Bot Notifications
TELEGRAM_BOT_TOKEN=XXXXXXXXXX:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
TELEGRAM_CHAT_ID=-XXXXXXX
TELEGRAM_TOPIC_ID=XXXXX

BACKUP_DIR=/path/to/backup/directory

GLUETUN_ENABLED=false
GLUETUN_API=httpXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Optional: when Gluetun forwards multiple ports, the API returns { "port": <first>, "ports": [<p0>, <p1>, ...] }.
# If GLUETUN_PORT_INDEX is set to an integer, that index of the "ports" array is used instead of "port".
# Leave it unset to keep the default behavior (use the single "port" value).
# GLUETUN_PORT_INDEX=0

# [EXPERIMENTAL] External connection (EC) client settings used by Mularr to reach aMule.
# Mularr is designed to work with the aMule instance it manages internally, so you should
# NOT set these unless you fully understand the implications. Changing them means connecting
# to an external aMule instance, a use case Mularr does not currently fully support or test.
# AMULE_EC_CLIENT_PASSWORD is only the client password used to authenticate the EC connection;
# it is NOT used to modify the internal aMule configuration. To change the EC password itself,
# edit the aMule configuration file (amule.conf) manually.
AMULE_EC_CLIENT_HOST=XXXXXXXXXXX
AMULE_EC_CLIENT_PORT=XXXX
AMULE_EC_CLIENT_PASSWORD=XXXXXXXXXXX